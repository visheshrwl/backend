# Lab platform connection settings.
# Codespaces/Gitpod inject these automatically. For a local `docker compose up`
# the defaults below already match the compose service hostnames/ports.

DATABASE_URL=postgresql://labs:labs@localhost:5432/labs
PGHOST=localhost
PGPORT=5432
PGUSER=labs
PGPASSWORD=labs
PGDATABASE=labs

REDIS_URL=redis://localhost:6379/0
