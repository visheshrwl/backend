{
  "name": "backend-labs",
  "dockerComposeFile": "docker-compose.yml",
  "service": "workspace",
  "workspaceFolder": "/workspaces/backend",
  "forwardPorts": [5432, 6379],
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/go:1": { "version": "1.22" },
    "ghcr.io/devcontainers/features/node:1": { "version": "22" },
    "ghcr.io/devcontainers/features/rust:1": {},
    "ghcr.io/devcontainers/features/ruby:1": { "version": "3.2" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "golang.go",
        "rust-lang.rust-analyzer",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y build-essential erlang libpq-dev && pip install -r .devcontainer/requirements.txt && pip install -e tooling/python/labkit && (cd tooling/node/labkit && npm install) && gem install --no-document pg redis && (cd tooling/rust/labkit && cargo build)",
  "remoteUser": "vscode"
}
