{
  "name": "backend-labs · Ruby",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "workspace",
  "workspaceFolder": "/workspaces/backend",
  "forwardPorts": [5432, 6379],
  "features": {
    "ghcr.io/devcontainers/features/ruby:1": { "version": "3.2" }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y libpq-dev && gem install --no-document pg redis",
  "customizations": {
    "vscode": { "extensions": ["Shopify.ruby-lsp"] }
  },
  "remoteUser": "vscode"
}
